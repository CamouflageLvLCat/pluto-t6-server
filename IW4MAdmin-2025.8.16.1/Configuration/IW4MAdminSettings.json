"ScriptInjection": "<link rel=\"canonical\" href=\"http://iw4madmin-br.ddns.net/\" /><script async src=\"https://www.googletagmanager.com/gtag/js?id=G-WMG705MJMD\"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-WMG705MJMD');$(document).off('click','.profile-ip-lookup');$(document).on('click','.profile-ip-lookup',function(e){e.preventDefault();const ip=$(this).data('ip')||$(this).text().trim();if(!/^(\\d{1,3}\\.){3}\\d{1,3}$/.test(ip))return;showLoader();fetch('https://ipinfo.io/'+ip+'/json').then(r=>r.json()).then(data=>{const html='<div><div><strong>IP:</strong> '+(data.ip||ip)+'</div><div><strong>Hostname:</strong> '+(data.hostname||'No Hostname')+'</div><div><strong>City:</strong> '+(data.city||'No City')+'</div><div><strong>Region:</strong> '+(data.region||'No Region')+'</div><div><strong>Country:</strong> '+(data.country||'No Country')+'</div><div><strong>Org:</strong> '+(data.org||'No Org')+'</div><div><strong>VPN:</strong> '+((data.privacy&&data.privacy.vpn)?'Yes':'No')+'</div><div><strong>Proxy:</strong> '+((data.privacy&&data.privacy.proxy)?'Yes':'No')+'</div><div class=\"mt-2\"><a href=\"https://ipinfo.io/'+ip+'\" target=\"_blank\">More info</a></div></div>';$('#actionModal .modal-message').hide();$('#actionModalContent').html(html);hideLoader();halfmoon.toggleModal('actionModal');}).catch(()=>{hideLoader();errorLoader();});});(function(){const applyCharts=()=>{if(!window.Chart||!Chart.instances)return;for(const k in Chart.instances){const c=Chart.instances[k];if(!c||!c.data||c._iw4mStyled)continue;c._iw4mStyled=true;c.data.datasets.forEach(d=>{d.borderColor='#117ac0';d.backgroundColor='rgba(17,122,192,0.1)';d.borderWidth=1;d.pointRadius=0;d.tension=0.3;});c.options.maintainAspectRatio=false;c.options.animation=false;c.update();}};const KEY='iw4m_selected_server';const applyServers=()=>{const links=document.querySelectorAll('a[href*=\"/Server/Scoreboard\"]');const saved=localStorage.getItem(KEY);links.forEach(a=>{const href=a.getAttribute('href');if(saved&&href===saved)a.classList.add('iw4m-server-selected');if(a.dataset.sel)return;a.dataset.sel=1;a.addEventListener('click',()=>{localStorage.setItem(KEY,href);links.forEach(x=>x.classList.remove('iw4m-server-selected'));a.classList.add('iw4m-server-selected');});});};const run=()=>{applyCharts();applyServers();};new MutationObserver(run).observe(document.body,{childList:true,subtree:true});window.addEventListener('DOMContentLoaded',run);})();</script>"
